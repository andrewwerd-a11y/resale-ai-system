# ─── Resale AI System — Environment Variables ───────────────────────────────
# Copy this file to .env and fill in your values.
# The system runs 100% locally — no cloud keys required for V1.

# ── Paths ────────────────────────────────────────────────────────────────────
# Root of your intake folder (where photo folders are placed)
# Windows example: C:\Users\YourName\ResaleInventory\intake
INTAKE_ROOT=./intake

# Where the SQLite database file lives
DB_PATH=./data/app.db

# Where exports (eBay CSV, master sheet) are written
EXPORT_DIR=./data/exports

# Where eBay report imports are read from
IMPORT_DIR=./data/imports

# ── Vision Model (Ollama) ─────────────────────────────────────────────────────
# Ollama must be running locally: https://ollama.com/download
# Pull your model first: ollama pull qwen2.5vl:7b
OLLAMA_BASE_URL=http://localhost:11434
VISION_MODEL_DEFAULT=qwen2.5vl:7b
VISION_MODEL_FALLBACK=minicpm-v
VISION_MODEL_PREMIUM=llama3.2-vision:11b

# ── Extraction settings ───────────────────────────────────────────────────────
# Confidence score below this threshold triggers review queue (0.0 – 1.0)
CONFIDENCE_REVIEW_THRESHOLD=0.72

# Items with estimated price above this (USD) always go to review
HIGH_VALUE_REVIEW_THRESHOLD=75.00

# ── API server ────────────────────────────────────────────────────────────────
API_HOST=127.0.0.1
API_PORT=8000
API_RELOAD=true

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_DIR=./data/logs

# ── Misc ──────────────────────────────────────────────────────────────────────
# Set to true to skip AI calls and use stub responses (for testing without Ollama)
DRY_RUN=false
