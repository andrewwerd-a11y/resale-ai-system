# Copy this file to .env and fill in your values

# Paths
INTAKE_ROOT=./intake
DB_PATH=./data/app.db
EXPORT_DIR=./data/exports
IMPORT_DIR=./data/imports

# AI / Ollama
OLLAMA_BASE_URL=http://localhost:11434
VISION_MODEL_DEFAULT=minicpm-v

# Thresholds
CONFIDENCE_REVIEW_THRESHOLD=0.72
HIGH_VALUE_REVIEW_THRESHOLD=75.00

# API Server
API_HOST=127.0.0.1
API_PORT=8000

# Misc
LOG_LEVEL=INFO
DRY_RUN=false

# eBay Sandbox credentials
EBAY_SANDBOX_APP_ID=
EBAY_SANDBOX_CERT_ID=
EBAY_SANDBOX_DEV_ID=
EBAY_SANDBOX_USER_TOKEN=

# eBay Production credentials
EBAY_PROD_APP_ID=
EBAY_PROD_CERT_ID=
EBAY_PROD_DEV_ID=
EBAY_PROD_USER_TOKEN=

# eBay shared settings
EBAY_RUNAME=
EBAY_ENVIRONMENT=sandbox
EBAY_MARKETPLACE_ID=EBAY_US

# Cloudinary (for photo hosting — free tier: 25 GB storage, 25 GB bandwidth/month)
# Sign up at https://cloudinary.com, then copy from your dashboard:
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
